{
    "rules": {
        ".read": false,
        ".write": false,
        "usuarios": {
            "$uid": {
                ".read": "$uid === auth.uid",
                ".write": "$uid === auth.uid"
            }
        },
        "invernaderos": {
            "$invId": {
                ".read": "auth !== null && root.child('usuarios/' + auth.uid + '/invernaderos/' + $invId).exists()",
                ".write": "auth !== null && root.child('usuarios/' + auth.uid + '/invernaderos/' + $invId).exists()",
                "secciones": {
                    "$secId": {
                        ".read": "auth !== null && root.child('usuarios/' + auth.uid + '/invernaderos/' + $invId).exists()",
                        ".write": "auth !== null && root.child('usuarios/' + auth.uid + '/invernaderos/' + $invId).exists()"
                    }
                }
            }
        },
        "modulos": {
            ".read": "auth !== null",
            "$moduloId": {
                "timestamp": {
                    ".write": true
                },
                "ip": {
                    ".write": true
                },
                "invernaderoId": {
                    ".write": "auth !== null && (newData.val() === null || root.child('usuarios/' + auth.uid + '/invernaderos/' + newData.val()).exists()) && (data.val() === null || !data.exists() || root.child('usuarios/' + auth.uid + '/invernaderos/' + data.val()).exists())"
                }
            }
        }
    }
}